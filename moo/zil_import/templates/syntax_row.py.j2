substrate = prep_route.get(prep_used) if prep_used else {{ bare_substrate_verb_repr }}
if not substrate:
    substrate = {{ substrate_verb_repr }}

# OBJECT-FUNCTIONs test the canonical ACTION verb (the matched syntax
# row's verb) — e.g. HOOK-F's HANG/PUT-ON, DRAIN-F's PUT-ON,
# ROBOT-PANEL-F's PUT-IN-FRONT — NOT the player's typed word ("put").
