if _.thing.dispatch_object_function(dobj, action_verb, prep_used, iobj, "pre"):
    return

# 2. iobj OBJECT-FUNCTION pre-phase (only when iobj resolved)
if iobj is not None and _.thing.dispatch_object_function(iobj, action_verb, prep_used, dobj, "pre-iobj"):
    return

# 3. ROOM-FUNCTION M-BEG
