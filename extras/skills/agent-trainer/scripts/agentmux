#!/usr/bin/env bash
# agentmux — manage moo-agent tmux sessions
#
# Usage:
#   agentmux [--group <name>] start [--restart-shell]
#   agentmux [--group <name>] stop
#   agentmux [--group <name>] restart [<agent>|--restart-shell]
#   agentmux [--group <name>] status
#   agentmux [--group <name>] check
#
# --group defaults to "tradesmen". Group configs live at:
#   extras/agents/groups/<name>.conf

set -euo pipefail

REPO="$(cd "$(dirname "$0")/../../../.." && pwd)"

# --- Parse --group flag (must come before the subcommand) ---
GROUP="tradesmen"
if [[ "${1:-}" == "--group" ]]; then
  GROUP="${2:?--group requires a name}"
  shift 2
fi

CONF="$REPO/extras/agents/groups/${GROUP}.conf"
if [[ ! -f "$CONF" ]]; then
  echo "Unknown group '$GROUP' — no config at $CONF" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$CONF"
# $SESSION, $AGENTS, $STALE_SECONDS are now set from the conf file

_kill_all() {
  pkill -f "moo-agent run extras/agents" 2>/dev/null || true
  tmux kill-session -t "$SESSION" 2>/dev/null || true
  sleep 1
}

_start_all() {
  local restart_shell=0
  [[ "${1:-}" == "--restart-shell" ]] && restart_shell=1

  if [[ $restart_shell -eq 1 ]]; then
    echo "Restarting django-moo-shell-1..."
    docker restart django-moo-shell-1
    sleep 5
  fi

  tmux new-session -d -s "$SESSION" -x 300 -y 120 -c "$REPO"

  for i in 1 2 3 4 5; do
    (( i < ${#AGENTS[@]} )) && tmux split-window -t "$SESSION" -c "$REPO"
  done

  tmux select-layout -t "$SESSION" tiled

  for i in "${!AGENTS[@]}"; do
    tmux send-keys -t "$SESSION:0.$i" "uv run moo-agent run extras/agents/${AGENTS[$i]}" Enter
    sleep 2
  done

  echo "Started ${#AGENTS[@]} agents in tmux session '$SESSION'."
  echo "Attach with: tmux attach -t $SESSION"
}

_status() {
  local now
  now=$(date +%s)
  printf "%-12s %-8s %-6s %s\n" "AGENT" "LOG" "AGE" "LAST LINE"
  printf "%-12s %-8s %-6s %s\n" "-----" "---" "---" "---------"
  for a in "${AGENTS[@]}"; do
    local log_dir="$REPO/extras/agents/$a/logs"
    local log
    log=$(find "$log_dir" -maxdepth 1 -name "*.log" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "")
    if [[ -z "$log" ]]; then
      printf "%-12s %-8s %-6s %s\n" "$a" "-" "-" "no logs"
      continue
    fi
    local log_path="$log_dir/$log"
    local last_line
    last_line=$(tail -1 "$log_path")
    local ts
    ts=$(echo "$last_line" | grep -oE '^\[([0-9]{2}:[0-9]{2}:[0-9]{2})\]' | tr -d '[]' || echo "")
    local age_str="-"
    local stale=""
    if [[ -n "$ts" ]]; then
      local log_date="${log:0:10}"
      local log_epoch
      log_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "${log_date} ${ts}" +%s 2>/dev/null || echo 0)
      local age=$(( now - log_epoch ))
      if (( age < 60 )); then
        age_str="${age}s"
      elif (( age < 3600 )); then
        age_str="$(( age / 60 ))m"
      else
        age_str="$(( age / 3600 ))h"
      fi
      (( age > STALE_SECONDS )) && stale=" [STALLED]"
    fi
    local display
    display=$(echo "$last_line" | sed 's/\x1b\[[0-9;]*m//g' | cut -c1-60)
    printf "%-12s %-8s %-6s %s%s\n" "$a" "${log:0:8}" "$age_str" "$display" "$stale"
  done
}

_pane_for() {
  local target="$1"
  for i in "${!AGENTS[@]}"; do
    [[ "${AGENTS[$i]}" == "$target" ]] && echo "$i" && return
  done
  echo "-1"
}

_agent_age() {
  local a="$1" now="$2"
  local log_dir="$REPO/extras/agents/$a/logs"
  local log
  log=$(find "$log_dir" -maxdepth 1 -name "*.log" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "")
  [[ -z "$log" ]] && echo -1 && return
  local last_line
  last_line=$(tail -1 "$log_dir/$log")
  local ts
  ts=$(echo "$last_line" | grep -oE '^\[([0-9]{2}:[0-9]{2}:[0-9]{2})\]' | tr -d '[]' || echo "")
  [[ -z "$ts" ]] && echo -1 && return
  local log_date="${log:0:10}"
  local log_epoch
  log_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "${log_date} ${ts}" +%s 2>/dev/null || echo 0)
  echo $(( now - log_epoch ))
}

_check() {
  local now
  now=$(date +%s)
  local any_stalled=0

  for a in "${AGENTS[@]}"; do
    local age
    age=$(_agent_age "$a" "$now")

    local pid
    pid=$(pgrep -f "moo-agent run extras/agents/$a" | head -1 || true)

    if [[ -n "$pid" ]]; then
      if (( age < 0 )); then
        echo "[$a] OK (running, no timestamped log yet)"
      elif (( age <= STALE_SECONDS )); then
        echo "[$a] OK (${age}s)"
      else
        echo "[$a] OK (${age}s, idle between cycles)"
      fi
      continue
    fi

    any_stalled=1
    if (( age < 0 )); then
      echo "[$a] CRASHED (no log) — restarting"
    else
      echo "[$a] CRASHED (${age}s) — restarting"
    fi
    local pane
    pane=$(_pane_for "$a")
    if (( pane >= 0 )) && tmux has-session -t "$SESSION" 2>/dev/null; then
      tmux send-keys -t "$SESSION:0.$pane" C-c "" Enter
      sleep 3
      tmux send-keys -t "$SESSION:0.$pane" "uv run moo-agent run extras/agents/$a" Enter
      echo "[$a] restarted in pane $pane"
    else
      echo "[$a] tmux session not found — run agentmux --group $GROUP start to rebuild"
    fi
  done

  (( any_stalled == 0 )) && echo "All agents healthy."
}

_restart_agents() {
  local restart_shell=1
  [[ "${1:-}" == "--no-restart-shell" ]] && restart_shell=0
  pkill -f "moo-agent run extras/agents" 2>/dev/null || true
  sleep 1
  if [[ $restart_shell -eq 1 ]]; then
    echo "Restarting django-moo-shell-1..."
    docker restart django-moo-shell-1
    sleep 5
  fi
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No existing session — starting fresh."
    _start_all "${1:-}"
  else
    for i in "${!AGENTS[@]}"; do
      tmux send-keys -t "$SESSION:0.$i" C-c "" Enter
      sleep 0.2
      tmux send-keys -t "$SESSION:0.$i" "uv run moo-agent run extras/agents/${AGENTS[$i]}" Enter
      sleep 2
    done
    echo "Restarted ${#AGENTS[@]} agents in existing session '$SESSION'."
  fi
}

_restart_one() {
  local name="$1"
  local pane
  pane=$(_pane_for "$name")
  if (( pane < 0 )); then
    echo "Unknown agent: $name. Valid names: ${AGENTS[*]}"
    exit 1
  fi
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No tmux session '$SESSION' — run agentmux --group $GROUP start first."
    exit 1
  fi
  pkill -f "moo-agent run extras/agents/$name" 2>/dev/null || true
  tmux send-keys -t "$SESSION:0.$pane" C-c "" Enter
  sleep 1
  tmux send-keys -t "$SESSION:0.$pane" "uv run moo-agent run extras/agents/$name" Enter
  echo "[$name] restarted in pane $pane."
}

case "${1:-}" in
  start)
    _kill_all
    _start_all "${2:-}"
    ;;
  stop)
    _kill_all
    echo "All agents stopped."
    ;;
  restart)
    if [[ -n "${2:-}" && "${2:-}" != "--restart-shell" && "${2:-}" != "--no-restart-shell" ]]; then
      _restart_one "$2"
    else
      _restart_agents "${2:-}"
    fi
    ;;
  status)
    _status
    ;;
  check)
    _check
    ;;
  *)
    echo "Usage: agentmux [--group <name>] {start|stop|restart|status|check}"
    echo "       agentmux [--group <name>] restart <agent>   Restart a single agent"
    echo "Groups: $(ls "$REPO/extras/agents/groups/"*.conf 2>/dev/null | xargs -n1 basename | sed 's/\.conf//' | tr '\n' ' ')"
    exit 1
    ;;
esac
