#!/usr/bin/env bash
# agentmux — manage moo-agent tmux sessions
#
# Usage:
#   agentmux [--group <name>] start [--restart-shell]
#   agentmux [--group <name>] stop
#   agentmux [--group <name>] restart [<agent>|--restart-shell]
#   agentmux [--group <name>] status
#   agentmux [--group <name>] check
#   agentmux [--group <name>] stats [--logs N]
#
# --group defaults to "tradesmen". Group configs live at:
#   extras/agents/groups/<name>.conf

set -euo pipefail

REPO="$(cd "$(dirname "$0")/../../../.." && pwd)"

# --- Parse --group flag (must come before the subcommand) ---
GROUP="tradesmen"
if [[ "${1:-}" == "--group" ]]; then
  GROUP="${2:?--group requires a name}"
  shift 2
fi

CONF="$REPO/extras/agents/groups/${GROUP}.conf"
if [[ ! -f "$CONF" ]]; then
  echo "Unknown group '$GROUP' — no config at $CONF" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$CONF"
# $SESSION, $AGENTS, $STALE_SECONDS are now set from the conf file

_kill_all() {
  pkill -f "moo-agent run extras/agents" 2>/dev/null || true
  tmux kill-session -t "$SESSION" 2>/dev/null || true
  sleep 1
}

_start_all() {
  local restart_shell=0
  [[ "${1:-}" == "--restart-shell" ]] && restart_shell=1

  if [[ $restart_shell -eq 1 ]]; then
    echo "Restarting django-moo-shell-1..."
    docker restart django-moo-shell-1
    sleep 5
  fi

  tmux new-session -d -s "$SESSION" -x 300 -y 120 -c "$REPO"

  if [[ -n "${TOKEN_CHAIN:-}" ]]; then
    tmux set-environment -t "$SESSION" MOO_TOKEN_CHAIN "$TOKEN_CHAIN"
  fi
  tmux set-environment -t "$SESSION" MOO_TOKEN_CHAIN_GROUP "$GROUP"
  tmux set-environment -t "$SESSION" MOO_AGENTMUX_PATH "$REPO/extras/skills/agent-trainer/scripts/agentmux"

  for (( i=1; i<${#AGENTS[@]}; i++ )); do
    tmux split-window -t "$SESSION" -c "$REPO"
  done

  if (( ${#AGENTS[@]} < 4 )); then
    tmux select-layout -t "$SESSION" even-horizontal
  else
    tmux select-layout -t "$SESSION" tiled
  fi

  local env_prefix="MOO_TOKEN_CHAIN_GROUP=${GROUP} MOO_AGENTMUX_PATH=${REPO}/extras/skills/agent-trainer/scripts/agentmux "
  [[ -n "${TOKEN_CHAIN:-}" ]] && env_prefix="MOO_TOKEN_CHAIN=${TOKEN_CHAIN} ${env_prefix}"

  for i in "${!AGENTS[@]}"; do
    local agent="${AGENTS[$i]}"
    if [[ -f "$REPO/extras/agents/$agent/paused" ]]; then
      echo "[$agent] PAUSED — skipping start (remove extras/agents/$agent/paused to re-enable)"
    else
      tmux send-keys -t "$SESSION:0.$i" "${env_prefix}uv run moo-agent run extras/agents/$agent" Enter
      sleep 2
    fi
  done

  # TOKEN_CHAIN is passed via env var to each agent process; brain.py handles
  # auto-start and auto-relay deterministically. No operator injection needed.

  echo "Started ${#AGENTS[@]} agents in tmux session '$SESSION'."
  echo "Attach with: tmux attach -t $SESSION"
}

_status() {
  local now
  now=$(date +%s)
  printf "%-12s %-8s %-6s %s\n" "AGENT" "LOG" "AGE" "LAST LINE"
  printf "%-12s %-8s %-6s %s\n" "-----" "---" "---" "---------"
  for a in "${AGENTS[@]}"; do
    local log_dir="$REPO/extras/agents/$a/logs"
    local log
    log=$(find "$log_dir" -maxdepth 1 -name "*.log" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "")
    if [[ -z "$log" ]]; then
      printf "%-12s %-8s %-6s %s\n" "$a" "-" "-" "no logs"
      continue
    fi
    local log_path="$log_dir/$log"
    local last_line
    last_line=$(tail -1 "$log_path")
    local ts
    ts=$(echo "$last_line" | grep -oE '^\[([0-9]{2}:[0-9]{2}:[0-9]{2})\]' | tr -d '[]' || echo "")
    local age_str="-"
    local stale=""
    if [[ -n "$ts" ]]; then
      local log_date="${log:0:10}"
      local log_epoch
      log_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "${log_date} ${ts}" +%s 2>/dev/null || echo 0)
      local age=$(( now - log_epoch ))
      if (( age < 60 )); then
        age_str="${age}s"
      elif (( age < 3600 )); then
        age_str="$(( age / 60 ))m"
      else
        age_str="$(( age / 3600 ))h"
      fi
      (( age > STALE_SECONDS )) && stale=" [STALLED]"
    fi
    local display
    display=$(echo "$last_line" | sed 's/\x1b\[[0-9;]*m//g' | cut -c1-60)
    printf "%-12s %-8s %-6s %s%s\n" "$a" "${log:0:8}" "$age_str" "$display" "$stale"
  done
}

_pane_for() {
  local target="$1"
  for i in "${!AGENTS[@]}"; do
    [[ "${AGENTS[$i]}" == "$target" ]] && echo "$i" && return
  done
  echo "-1"
}

_agent_age() {
  local a="$1" now="$2"
  local log_dir="$REPO/extras/agents/$a/logs"
  local log
  log=$(find "$log_dir" -maxdepth 1 -name "*.log" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 | xargs basename 2>/dev/null || echo "")
  [[ -z "$log" ]] && echo -1 && return
  local last_line
  last_line=$(tail -1 "$log_dir/$log")
  local ts
  ts=$(echo "$last_line" | grep -oE '^\[([0-9]{2}:[0-9]{2}:[0-9]{2})\]' | tr -d '[]' || echo "")
  [[ -z "$ts" ]] && echo -1 && return
  local log_date="${log:0:10}"
  local log_epoch
  log_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "${log_date} ${ts}" +%s 2>/dev/null || echo 0)
  echo $(( now - log_epoch ))
}

_check() {
  local now
  now=$(date +%s)
  local any_stalled=0

  for a in "${AGENTS[@]}"; do
    local age
    age=$(_agent_age "$a" "$now")

    local pid
    pid=$(pgrep -f "moo-agent run extras/agents/$a" | head -1 || true)

    if [[ -n "$pid" ]]; then
      if (( age < 0 )); then
        echo "[$a] OK (running, no timestamped log yet)"
      elif (( age <= STALE_SECONDS )); then
        echo "[$a] OK (${age}s)"
      else
        echo "[$a] OK (${age}s, idle between cycles)"
      fi
      continue
    fi

    # Honour intentional pause — do not auto-restart paused agents.
    if [[ -f "$REPO/extras/agents/$a/paused" ]]; then
      echo "[$a] PAUSED (intentionally stopped — remove extras/agents/$a/paused to re-enable)"
      continue
    fi

    any_stalled=1
    if (( age < 0 )); then
      echo "[$a] CRASHED (no log) — restarting"
    else
      echo "[$a] CRASHED (${age}s) — restarting"
    fi
    local pane
    pane=$(_pane_for "$a")
    if (( pane >= 0 )) && tmux has-session -t "$SESSION" 2>/dev/null; then
      tmux send-keys -t "$SESSION:0.$pane" C-c "" Enter
      sleep 3
      tmux send-keys -t "$SESSION:0.$pane" "uv run moo-agent run extras/agents/$a" Enter
      echo "[$a] restarted in pane $pane"
    else
      echo "[$a] tmux session not found — run agentmux --group $GROUP start to rebuild"
    fi
  done

  (( any_stalled == 0 )) && echo "All agents healthy."
}

_restart_agents() {
  local restart_shell=0
  [[ "${1:-}" == "--restart-shell" ]] && restart_shell=1
  pkill -f "moo-agent run extras/agents" 2>/dev/null || true
  sleep 1
  if [[ $restart_shell -eq 1 ]]; then
    echo "Restarting django-moo-shell-1..."
    docker restart django-moo-shell-1
    sleep 5
  fi
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    if [[ -n "${TOKEN_CHAIN:-}" ]]; then
      tmux set-environment -t "$SESSION" MOO_TOKEN_CHAIN "$TOKEN_CHAIN"
    fi
    tmux set-environment -t "$SESSION" MOO_TOKEN_CHAIN_GROUP "$GROUP"
    tmux set-environment -t "$SESSION" MOO_AGENTMUX_PATH "$REPO/extras/skills/agent-trainer/scripts/agentmux"
  fi

  local env_prefix="MOO_TOKEN_CHAIN_GROUP=${GROUP} MOO_AGENTMUX_PATH=${REPO}/extras/skills/agent-trainer/scripts/agentmux "
  [[ -n "${TOKEN_CHAIN:-}" ]] && env_prefix="MOO_TOKEN_CHAIN=${TOKEN_CHAIN} ${env_prefix}"

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No existing session — starting fresh."
    _start_all "${1:-}"
  else
    for i in "${!AGENTS[@]}"; do
      tmux send-keys -t "$SESSION:0.$i" C-c "" Enter
      sleep 0.2
      tmux send-keys -t "$SESSION:0.$i" "${env_prefix}uv run moo-agent run extras/agents/${AGENTS[$i]}" Enter
      sleep 2
    done
    echo "Restarted ${#AGENTS[@]} agents in existing session '$SESSION'."
  fi
}

_stats() {
  local logs_per_agent=3
  if [[ "${1:-}" == "--logs" ]]; then
    logs_per_agent="${2:?--logs requires a count}"
    shift 2
  fi
  REPO="$REPO" AGENTS="${AGENTS[*]}" LOGS_N="$logs_per_agent" python3 - <<'PYEOF'
import os, re, glob

repo = os.environ["REPO"]
agents = os.environ["AGENTS"].split()
logs_n = int(os.environ["LOGS_N"])

fmt = "{:<14} {:>7} {:>9} {:>9} {:>9} {:>9} {:>9} {:>9}"
print(fmt.format("AGENT", "CYCLES", "AVG_DUR", "P50", "P95", "MAX_DUR", "AVG_CMDS", "MAX_CMDS"))
print(fmt.format("-----", "------", "-------", "---", "---", "-------", "--------", "--------"))

pat = re.compile(
    r"\[Cycle\] duration=([0-9.]+)s tool_calls=(\d+) commands=(\d+) script_lines=(\d+)"
)

for a in agents:
    log_dir = os.path.join(repo, "extras/agents", a, "logs")
    logs = sorted(
        glob.glob(os.path.join(log_dir, "*.log")),
        key=os.path.getmtime,
        reverse=True,
    )[:logs_n]
    durs, cmds = [], []
    for log_path in logs:
        try:
            with open(log_path) as f:
                for line in f:
                    m = pat.search(line)
                    if not m:
                        continue
                    durs.append(float(m.group(1)))
                    cmds.append(int(m.group(3)))
        except OSError:
            pass
    if not durs:
        print(fmt.format(a, 0, "-", "-", "-", "-", "-", "-"))
        continue
    n = len(durs)
    ds = sorted(durs)

    def pct(p):
        i = max(0, min(n - 1, int(round(p * n)) - 1))
        return ds[i]

    print(
        fmt.format(
            a,
            n,
            f"{sum(durs)/n:.1f}s",
            f"{pct(0.5):.1f}s",
            f"{pct(0.95):.1f}s",
            f"{max(durs):.1f}s",
            f"{sum(cmds)/n:.1f}",
            max(cmds),
        )
    )
PYEOF
}

_cycle_age() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: agentmux [--group <name>] cycle-age <agent>" >&2
    exit 1
  fi
  local found=0
  for a in "${AGENTS[@]}"; do
    [[ "$a" == "$name" ]] && found=1 && break
  done
  if (( found == 0 )); then
    echo "Unknown agent '$name' in group '$GROUP'. Valid: ${AGENTS[*]}" >&2
    exit 1
  fi
  local log_dir="$REPO/extras/agents/$name/logs"
  if [[ ! -d "$log_dir" ]]; then
    echo "No log directory for $name at $log_dir" >&2
    exit 2
  fi
  REPO="$REPO" AGENT="$name" python3 - <<'PYEOF'
import os, re, glob, time
from datetime import datetime

repo = os.environ["REPO"]
agent = os.environ["AGENT"]
log_dir = os.path.join(repo, "extras/agents", agent, "logs")
logs = sorted(
    glob.glob(os.path.join(log_dir, "*.log")),
    key=os.path.getmtime,
    reverse=True,
)[:3]

cycle_line_re = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] \[Cycle\] duration=([0-9.]+)s")
durs = []
last_ts_epoch = -1
for log_path in logs:
    log_name = os.path.basename(log_path)
    log_date = log_name[:10]
    try:
        with open(log_path) as f:
            for line in f:
                m = cycle_line_re.match(line)
                if not m:
                    continue
                durs.append(float(m.group(2)))
                try:
                    dt = datetime.strptime(f"{log_date} {m.group(1)}", "%Y-%m-%d %H:%M:%S")
                    ep = int(dt.timestamp())
                    if ep > last_ts_epoch:
                        last_ts_epoch = ep
                except ValueError:
                    pass
    except OSError:
        pass

if last_ts_epoch < 0:
    age = -1
else:
    age = int(time.time() - last_ts_epoch)

if len(durs) < 5:
    p95 = -1.0
else:
    ds = sorted(durs)
    i = max(0, min(len(ds) - 1, int(round(0.95 * len(ds))) - 1))
    p95 = ds[i]

print(f"{age} {p95}")
PYEOF
}

_restart_one() {
  local name="$1"
  local pane
  pane=$(_pane_for "$name")
  if (( pane < 0 )); then
    echo "Unknown agent: $name. Valid names: ${AGENTS[*]}"
    exit 1
  fi
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No tmux session '$SESSION' — run agentmux --group $GROUP start first."
    exit 1
  fi
  local env_prefix="MOO_TOKEN_CHAIN_GROUP=${GROUP} MOO_AGENTMUX_PATH=${REPO}/extras/skills/agent-trainer/scripts/agentmux "
  [[ -n "${TOKEN_CHAIN:-}" ]] && env_prefix="MOO_TOKEN_CHAIN=${TOKEN_CHAIN} ${env_prefix}"

  if [[ -f "$REPO/extras/agents/$name/paused" ]]; then
    echo "[$name] PAUSED — remove extras/agents/$name/paused first, then retry."
    exit 1
  fi

  pkill -f "moo-agent run extras/agents/$name" 2>/dev/null || true
  tmux send-keys -t "$SESSION:0.$pane" C-c "" Enter
  sleep 1
  tmux send-keys -t "$SESSION:0.$pane" "${env_prefix}uv run moo-agent run extras/agents/$name" Enter
  echo "[$name] restarted in pane $pane."
}

case "${1:-}" in
  start)
    _kill_all
    _start_all "${2:-}"
    ;;
  stop)
    _kill_all
    echo "All agents stopped."
    ;;
  restart)
    if [[ -n "${2:-}" && "${2:-}" != "--restart-shell" && "${2:-}" != "--no-restart-shell" ]]; then
      _restart_one "$2"
    else
      _restart_agents "${2:-}"
    fi
    ;;
  status)
    _status
    ;;
  check)
    _check
    ;;
  stats)
    shift
    _stats "$@"
    ;;
  cycle-age)
    _cycle_age "${2:-}"
    ;;
  *)
    echo "Usage: agentmux [--group <name>] {start|stop|restart|status|check|stats|cycle-age}"
    echo "       agentmux [--group <name>] restart <agent>     Restart a single agent"
    echo "       agentmux [--group <name>] stats [--logs N]    Per-agent cycle runtime stats"
    echo "       agentmux [--group <name>] cycle-age <agent>   Print '<age_s> <p95_s>' for agent"
    echo "Groups: $(ls "$REPO/extras/agents/groups/"*.conf 2>/dev/null | xargs -n1 basename | sed 's/\.conf//' | tr '\n' ' ')"
    exit 1
    ;;
esac
